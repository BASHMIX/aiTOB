# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Start.gg Configuration
STARTGG_API_TOKEN=your_startgg_token_here

# Google Gemini Configuration (AI Referee & Safety)
GOOGLE_API_KEY=your_google_api_key_here

# Database Configuration
DB_PATH=backend/core/database.sqlite

# Hub Configuration
HUB_PASSWORD=your_admin_hub_password_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration
# Comma-separated list of browser origins allowed to call the API.
# Leave empty for local dev (falls back to localhost:5173 / localhost:8000).
# Production example: https://hub.mydomain.com,https://overlays.mydomain.com
ALLOWED_ORIGINS=
# Optional: regex to allow a whole subdomain space (cloud-hosted OBS overlays).
# Example: https://.*\.mydomain\.com
ALLOWED_ORIGIN_REGEX=
